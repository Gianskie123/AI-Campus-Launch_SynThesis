# Use AIMLAPI if you are following the uploaded backend.
AIMLAPI_KEY=your_aimlapi_key_here
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1

# Or use OpenAI directly instead of AIMLAPI.
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=theses
SYNTHESIS_EMBED_MODEL=text-embedding-3-small
SYNTHESIS_CHAT_MODEL=gpt-4o
SYNTHESIS_VECTOR_SIZE=1536
CORS_ORIGINS=*
